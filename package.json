{
  "name": "pulso-crm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.5.0",
  "scripts": {
    "dev": "pnpm --filter @pulso/web dev",
    "build": "pnpm --filter @pulso/web build",
    "start": "pnpm --filter @pulso/web start",
    "lint": "pnpm --filter @pulso/web lint",
    "typecheck": "pnpm --filter @pulso/web typecheck",
    "test": "pnpm --filter @pulso/web test",
    "test:e2e": "pnpm --filter @pulso/web test:e2e",
    "db:generate": "pnpm --filter @pulso/database db:generate",
    "db:migrate": "pnpm --filter @pulso/database db:migrate",
    "db:studio": "pnpm --filter @pulso/database db:studio",
    "db:seed": "pnpm --filter @pulso/database db:seed",
    "check": "pnpm --filter @pulso/web typecheck && pnpm --filter @pulso/web test && pnpm --filter @pulso/web build"
  },
  "engines": {"node": ">=20.9"}
}
